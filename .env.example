# ============================================================
# RapLab ortam değişkenleri — Şartname 33: anahtarlar koda yazılmaz
# Bu dosyayı .env.local olarak kopyala ve değerleri doldur.
# Değerler tanımlı DEĞİLSE uygulama DEMO modunda (kurgusal veri) çalışır.
# ============================================================

# Supabase projesi (https://supabase.com/dashboard → Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# YALNIZCA sunucu tarafı — istemciye asla gönderilmez (26.4)
SUPABASE_SERVICE_ROLE_KEY=

# OAuth yönlendirmeleri için site adresi
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase yapılandırılmış olsa bile demo modunu zorla (geliştirme)
# RAPLAB_FORCE_DEMO=true
